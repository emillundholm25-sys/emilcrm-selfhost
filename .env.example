# EmilCRM environment variables
#
# All are OPTIONAL until you want persistence + auth. With none set, the app
# runs exactly as before (localStorage only, no login) — so deploys never break.

# --- Database (Neon Postgres) ---
# Set automatically when you add Vercel Postgres/Neon to the project.
# Locally, run: vercel env pull .env.local
DATABASE_URL=

# --- Auth (single password gate) ---
# Auth is ONLY enforced when BOTH of these are set.
# APP_PASSWORD: the password you'll type to sign in (choose your own).
# AUTH_SECRET:  a random secret for signing the session cookie
#               (generate with: openssl rand -base64 32)
APP_PASSWORD=
AUTH_SECRET=

# --- Ingest API (Cowork prospecting plugin) ---
# Bearer token for POST/GET /api/ingest, so the agent can read the ICP and write
# prospects without a browser. Machine-only — separate from APP_PASSWORD.
# Generate with: openssl rand -base64 32
# The ingest endpoint is disabled (503) until this is set.
INGEST_TOKEN=

# --- AI: cold-call scripts + call summaries (Anthropic) ---
# Enables the in-app "Generate call script" button and the AI summary of each
# call transcript. The Cold-call card is read-only guidance until this is set.
# Get a key at https://console.anthropic.com  (generate with their console).
ANTHROPIC_API_KEY=
# Optional: override the model (defaults to claude-opus-4-8). Set
# claude-sonnet-4-6 to lower per-call cost.
ANTHROPIC_MODEL=

# --- Telephony: CloudTalk click-to-call + transcription ---
# All three are required to show the "Call via CloudTalk" button. The call rings
# your CloudTalk agent first, then dials the contact.
# Create an API key under CloudTalk → Settings → API keys.
CLOUDTALK_ACCESS_KEY_ID=
CLOUDTALK_ACCESS_KEY_SECRET=
# The numeric agent id whose phone should ring first (CloudTalk → Agents).
CLOUDTALK_AGENT_ID=
# Shared secret for the call webhook. In CloudTalk, add a Workflow Automation
# that POSTs finished-call data (incl. transcript) to:
#   https://YOUR-APP.vercel.app/api/cloudtalk/webhook?token=THIS_VALUE
# Generate with: openssl rand -base64 32
CLOUDTALK_WEBHOOK_SECRET=

# --- Swedish company data: Bolagsverket enrichment (free open data) ---
# Enables `emilcrm_enrich_company` (MCP) + the public company-lookup: org-nr →
# official firmographics (name, SNI industry, city, legal form) + ICP-fit score.
# The API is FREE (EU high-value-datasets), but needs a one-time "kundanmälan":
#   bolagsverket.se/apierochoppnadata/hamtaforetagsinformation/vardefulladatamangder
# You'll be emailed/SMS'd a client id + secret for the "Värdefulla datamängder"
# API. Enrichment is dormant until BOTH are set.
BOLAGSVERKET_CLIENT_ID=
BOLAGSVERKET_CLIENT_SECRET=
# Optional overrides (defaults are the production Bolagsverket endpoints):
# BOLAGSVERKET_TOKEN_URL=https://portal.api.bolagsverket.se/oauth2/token
# BOLAGSVERKET_API_BASE=https://gw.api.bolagsverket.se/vardefulla-datamangder/v1

# --- License gate (sold / self-hosted builds) ---
# DORMANT by default. The gate is only enforced when REQUIRE_LICENSE is truthy,
# so a fresh clone or your own instance is never locked out. The distributed
# product template sets REQUIRE_LICENSE=1; buyers then activate with their key
# (validated against Lemon Squeezy — no API secret needed, just the key).
# LICENSE_KEY is optional: buyers can instead paste the key in the activation
# screen, which stores it in the database.
REQUIRE_LICENSE=1
LICENSE_KEY=
