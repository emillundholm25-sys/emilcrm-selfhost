# EmilCRM environment variables
#
# All are OPTIONAL until you want persistence + auth. With none set, the app
# runs exactly as before (localStorage only, no login) — so deploys never break.

# --- Database (Neon Postgres) ---
# Set automatically when you add Vercel Postgres/Neon to the project.
# Locally, run: vercel env pull .env.local
DATABASE_URL=

# --- Auth (single password gate) ---
# Auth is ONLY enforced when BOTH of these are set.
# APP_PASSWORD: the password you'll type to sign in (choose your own).
# AUTH_SECRET:  a random secret for signing the session cookie
#               (generate with: openssl rand -base64 32)
APP_PASSWORD=
AUTH_SECRET=

# --- Ingest API (Cowork prospecting plugin) ---
# Bearer token for POST/GET /api/ingest, so the agent can read the ICP and write
# prospects without a browser. Machine-only — separate from APP_PASSWORD.
# Generate with: openssl rand -base64 32
# The ingest endpoint is disabled (503) until this is set.
INGEST_TOKEN=

# --- License gate (sold / self-hosted builds) ---
# DORMANT by default. The gate is only enforced when REQUIRE_LICENSE is truthy,
# so a fresh clone or your own instance is never locked out. The distributed
# product template sets REQUIRE_LICENSE=1; buyers then activate with their key
# (validated against Lemon Squeezy — no API secret needed, just the key).
# LICENSE_KEY is optional: buyers can instead paste the key in the activation
# screen, which stores it in the database.
REQUIRE_LICENSE=1
LICENSE_KEY=
